<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pure_white"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Logo lockup: concentric rings + wordmark -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_rings" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="@color/ink_black"
            android:textSize="15sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Step 1: language — rotating multilingual greeting, conversation-style -->
        <LinearLayout
            android:id="@+id/stepLanguage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="-36dp"
                    android:layout_marginTop="-8dp"
                    android:alpha="0.35"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_sparkle" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="-28dp"
                    android:layout_marginBottom="4dp"
                    android:alpha="0.35"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_sparkle" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/greetingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond_light"
                        android:gravity="center"
                        android:letterSpacing="-0.015"
                        android:text="Selamat datang!"
                        android:textColor="@color/ink_black"
                        android:textSize="40sp" />

                    <TextView
                        android:id="@+id/promptText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="Bahasa apa yang ingin Anda gunakan?"
                        android:textColor="@color/ash_gray"
                        android:textSize="18sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Bahasa Indonesia option -->
            <LinearLayout
                android:id="@+id/optionIndonesian"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_card_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:padding="20dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_flag_id" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Bahasa Indonesia"
                    android:textColor="@color/ink_black"
                    android:textSize="18sp" />
            </LinearLayout>

            <!-- English option -->
            <LinearLayout
                android:id="@+id/optionEnglish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:padding="20dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_flag_gb" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="English"
                    android:textColor="@color/ink_black"
                    android:textSize="18sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Step 2: role — select a card, then Continue (localized) -->
        <LinearLayout
            android:id="@+id/stepRole"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="-36dp"
                    android:layout_marginTop="-8dp"
                    android:alpha="0.35"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_sparkle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond_light"
                    android:gravity="center"
                    android:letterSpacing="-0.015"
                    android:text="@string/role_title"
                    android:textColor="@color/ink_black"
                    android:textSize="34sp" />
            </FrameLayout>

            <!-- Ibu Sri — Elder (instant entry) -->
            <LinearLayout
                android:id="@+id/optionSenior"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_card_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:padding="20dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_senior" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/role_elder"
                        android:textColor="@color/ink_black"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/role_elder_sub"
                        android:textColor="@color/slate_gray"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Dewi — Guardian (instant entry) -->
            <LinearLayout
                android:id="@+id/optionGuardian"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:padding="20dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_volunteer" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/role_guardian_name"
                        android:textColor="@color/ink_black"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/role_guardian_sub"
                        android:textColor="@color/slate_gray"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Sari — Social Worker (instant entry) -->
            <LinearLayout
                android:id="@+id/optionCare"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="76dp"
                android:orientation="horizontal"
                android:padding="20dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_care" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/role_care_name"
                        android:textColor="@color/ink_black"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/role_care_sub"
                        android:textColor="@color/slate_gray"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/authLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:padding="12dp"
                android:text="@string/auth_link"
                android:textColor="@color/signal_violet"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/backToLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:text="@string/back"
                android:textColor="@color/ink_black"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Step 3: font size (seniors only) — live preview slider + OK -->
        <LinearLayout
            android:id="@+id/stepFont"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/cormorant_garamond_light"
                android:gravity="center"
                android:letterSpacing="-0.015"
                android:text="@string/font_title"
                android:textColor="@color/ink_black"
                android:textSize="34sp" />

            <TextView
                android:id="@+id/fontPreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="@string/font_preview"
                android:textColor="@color/ash_gray"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textColor="@color/ink_black"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/fontSlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:max="4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textColor="@color/ink_black"
                    android:textSize="24sp" />
            </LinearLayout>

            <Button
                android:id="@+id/fontOkButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_button_pill"
                android:stateListAnimator="@null"
                android:text="OK"
                android:textAllCaps="false"
                android:textColor="@color/pure_white"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/backToRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:text="@string/back"
                android:textColor="@color/ink_black"
                android:textSize="15sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Section divider stripe: mint / violet / ink -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/mint_pulse" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/signal_violet" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/ink_black" />
    </LinearLayout>
</LinearLayout>
