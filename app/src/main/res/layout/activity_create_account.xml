<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pure_white"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Logo lockup: concentric rings + wordmark -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_rings" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="@color/ink_black"
            android:textSize="15sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Editorial headline block with atmospheric sparkles -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="-36dp"
                    android:layout_marginTop="-8dp"
                    android:alpha="0.35"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_sparkle" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="-28dp"
                    android:layout_marginBottom="4dp"
                    android:alpha="0.35"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_sparkle" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="-44dp"
                    android:alpha="0.35"
                    android:background="@drawable/bg_sparkle_dot" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond_light"
                        android:letterSpacing="-0.015"
                        android:text="@string/create_account"
                        android:textColor="@color/ink_black"
                        android:textSize="34sp" />

                    <TextView
                        android:id="@+id/createSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="@string/create_account_subtitle"
                        android:textColor="@color/ash_gray"
                        android:textSize="15sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Content card: hairline border, 16px radius, 24px padding, no shadow -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/full_name_label"
                    android:textColor="@color/ash_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/nameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="name"
                    android:background="@drawable/bg_input"
                    android:fontFamily="@font/inter_regular"
                    android:hint="@string/full_name_hint"
                    android:importantForAutofill="yes"
                    android:inputType="textPersonName|textCapWords"
                    android:maxLines="1"
                    android:padding="14dp"
                    android:textColor="@color/ink_black"
                    android:textColorHint="@color/mist_gray"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/nameError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/error_name"
                    android:textColor="@color/slate_gray"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/gender_label"
                    android:textColor="@color/ash_gray"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/genderFemale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_option_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minHeight="48dp"
                        android:padding="12dp"
                        android:text="@string/gender_female"
                        android:textColor="@color/ink_black"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/genderMale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_option_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minHeight="48dp"
                        android:padding="12dp"
                        android:text="@string/gender_male"
                        android:textColor="@color/ink_black"
                        android:textSize="15sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/genderError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/error_gender"
                    android:textColor="@color/slate_gray"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/email_label"
                    android:textColor="@color/ash_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="emailAddress"
                    android:background="@drawable/bg_input"
                    android:fontFamily="@font/inter_regular"
                    android:hint="@string/email_hint"
                    android:importantForAutofill="yes"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:padding="14dp"
                    android:textColor="@color/ink_black"
                    android:textColorHint="@color/mist_gray"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/emailError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/error_email"
                    android:textColor="@color/slate_gray"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/password_label"
                    android:textColor="@color/ash_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="newPassword"
                    android:background="@drawable/bg_input"
                    android:fontFamily="@font/inter_regular"
                    android:hint="@string/password_hint"
                    android:importantForAutofill="yes"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:padding="14dp"
                    android:textColor="@color/ink_black"
                    android:textColorHint="@color/mist_gray"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/passwordError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/error_password"
                    android:textColor="@color/slate_gray"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/confirm_password_label"
                    android:textColor="@color/ash_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/confirmPasswordInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="newPassword"
                    android:background="@drawable/bg_input"
                    android:fontFamily="@font/inter_regular"
                    android:hint="@string/confirm_password_hint"
                    android:importantForAutofill="yes"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:padding="14dp"
                    android:textColor="@color/ink_black"
                    android:textColorHint="@color/mist_gray"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/confirmPasswordError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/error_confirm"
                    android:textColor="@color/slate_gray"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/createAccountButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_pill"
                    android:stateListAnimator="@null"
                    android:text="@string/create_account"
                    android:textAllCaps="false"
                    android:textColor="@color/pure_white"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/signInLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:padding="8dp"
                android:text="@string/have_account"
                android:textColor="@color/ink_black"
                android:textSize="15sp" />
        </LinearLayout>
    </ScrollView>

    <!-- Section divider stripe: mint / violet / ink -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/mint_pulse" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/signal_violet" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/ink_black" />
    </LinearLayout>
</LinearLayout>
