<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pure_white"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Logo lockup -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_rings" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="@color/ink_black"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Featured companion message: large serif, the conversational focus -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/companionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cormorant_garamond_light"
            android:letterSpacing="-0.015"
            android:text="@string/loading_elder"
            android:textColor="@color/ink_black"
            android:textSize="28sp" />
    </LinearLayout>

    <!-- Transcript -->
    <ScrollView
        android:id="@+id/transcriptScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Guided-choice options (V2.2 §C): big buttons replace the keyboard -->
    <LinearLayout
        android:id="@+id/guidedRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/guidedYes"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:text="@string/guided_yes"
                android:textColor="@color/ink_black"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/guidedNo"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:text="@string/guided_no"
                android:textColor="@color/ink_black"
                android:textSize="17sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/guidedUnknown"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:text="@string/guided_unknown"
                android:textColor="@color/ink_black"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/guidedDelegate"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_selected"
                android:gravity="center"
                android:text="@string/guided_delegate"
                android:textColor="@color/ink_black"
                android:textSize="17sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Input row -->
    <LinearLayout
        android:id="@+id/inputRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp">

        <EditText
            android:id="@+id/chatInput"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:fontFamily="@font/inter_regular"
            android:hint="@string/chat_hint"
            android:imeOptions="actionSend"
            android:importantForAutofill="no"
            android:inputType="textCapSentences"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/ink_black"
            android:textColorHint="@color/mist_gray"
            android:textSize="18sp" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_button_pill"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:stateListAnimator="@null"
            android:text="@string/send"
            android:textAllCaps="false"
            android:textColor="@color/pure_white"
            android:textSize="17sp" />
    </LinearLayout>

    <!-- Section divider stripe: mint / violet / ink -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/mint_pulse" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/signal_violet" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/ink_black" />
    </LinearLayout>
</LinearLayout>
