<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pure_white"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Logo lockup -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_rings" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="@color/ink_black"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- One question per screen, spoken AND shown (V2.2 §C.1) -->
        <TextView
            android:id="@+id/guidedQuestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cormorant_garamond_light"
            android:gravity="center"
            android:letterSpacing="-0.015"
            android:textColor="@color/ink_black"
            android:textSize="34sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/guidedYes"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:text="@string/guided_yes"
                android:textColor="@color/ink_black"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/guidedNo"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:text="@string/guided_no"
                android:textColor="@color/ink_black"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <!-- Universal escape hatches (V2.2 §C): always valid answers -->
            <TextView
                android:id="@+id/guidedUnknown"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:text="@string/guided_unknown"
                android:textColor="@color/ink_black"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/guidedDelegate"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_selected"
                android:gravity="center"
                android:text="@string/guided_delegate"
                android:textColor="@color/ink_black"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Section divider stripe: mint / violet / ink -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/mint_pulse" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/signal_violet" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/ink_black" />
    </LinearLayout>
</LinearLayout>
