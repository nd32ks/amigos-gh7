<?xml version="1.0" encoding="utf-8"?>
<!-- Match Found modal (ui_spec.md §2): serif headline + group card + one action -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/matchTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/cormorant_garamond_light"
        android:letterSpacing="-0.015"
        android:text="@string/match_title"
        android:textColor="@color/ink_black"
        android:textSize="26sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_selected"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/matchGroupName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ink_black"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/matchDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/slate_gray"
            android:textSize="13sp" />
    </LinearLayout>

    <Button
        android:id="@+id/matchNotify"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_button_pill"
        android:stateListAnimator="@null"
        android:text="@string/match_notify"
        android:textAllCaps="false"
        android:textColor="@color/pure_white"
        android:textSize="15sp" />
</LinearLayout>
