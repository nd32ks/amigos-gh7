<?xml version="1.0" encoding="utf-8"?>
<!-- Right-edge navigation drawer -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:background="@color/pure_white"
    android:orientation="vertical"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_rings" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="@color/ink_black"
            android:textSize="15sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="12dp"
        android:background="@color/fog_gray" />

    <TextView
        android:id="@+id/menuCompanion"
        style="@style/MenuRow"
        android:drawableStart="@drawable/ic_senior"
        android:text="@string/menu_companion" />

    <TextView
        android:id="@+id/menuDashboard"
        style="@style/MenuRow"
        android:drawableStart="@drawable/ic_volunteer"
        android:text="@string/menu_dashboard" />

    <TextView
        android:id="@+id/menuCare"
        style="@style/MenuRow"
        android:drawableStart="@drawable/ic_care"
        android:text="@string/menu_care" />

    <TextView
        android:id="@+id/menuDiary"
        style="@style/MenuRow"
        android:drawableStart="@drawable/ic_sparkle"
        android:text="@string/menu_diary" />

    <TextView
        android:id="@+id/menuWizard"
        style="@style/MenuRow"
        android:drawableStart="@drawable/ic_check"
        android:text="@string/menu_wizard" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@color/fog_gray" />

    <TextView
        android:id="@+id/menuRole"
        style="@style/MenuRow"
        android:drawableStart="@drawable/ic_rings"
        android:text="@string/menu_role" />

    <TextView
        android:id="@+id/menuLogin"
        style="@style/MenuRow"
        android:drawableStart="@drawable/ic_senior"
        android:text="@string/menu_login" />
</LinearLayout>
