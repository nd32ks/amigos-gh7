<?xml version="1.0" encoding="utf-8"?>
<!-- Union Jack, monochrome line-art (DESIGN.md: ink strokes, no extra colors) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- diagonals -->
    <path
        android:pathData="M4.75,6.75 L19.25,17.25 M19.25,6.75 L4.75,17.25"
        android:strokeColor="@color/ink_black"
        android:strokeWidth="0.9"
        android:fillColor="@android:color/transparent" />
    <!-- center cross -->
    <path
        android:pathData="M12,6.75 L12,17.25 M4.75,12 L19.25,12"
        android:strokeColor="@color/ink_black"
        android:strokeWidth="1.6"
        android:fillColor="@android:color/transparent" />
    <!-- flag outline -->
    <path
        android:pathData="M4.75,6.75 L19.25,6.75 L19.25,17.25 L4.75,17.25 Z"
        android:strokeColor="@color/ink_black"
        android:strokeWidth="1.2"
        android:fillColor="@android:color/transparent" />
</vector>
