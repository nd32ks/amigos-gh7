<?xml version="1.0" encoding="utf-8"?>
<!-- Indonesian flag, monochrome line-art (DESIGN.md: ink strokes, no extra colors) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- top band (red, rendered in ink) -->
    <path
        android:pathData="M4.75,6.75 L19.25,6.75 L19.25,12 L4.75,12 Z"
        android:fillColor="@color/ink_black" />
    <!-- flag outline -->
    <path
        android:pathData="M4.75,6.75 L19.25,6.75 L19.25,17.25 L4.75,17.25 Z"
        android:strokeColor="@color/ink_black"
        android:strokeWidth="1.2"
        android:fillColor="@android:color/transparent" />
</vector>
