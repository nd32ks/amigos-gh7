<?xml version="1.0" encoding="utf-8"?>
<!-- Role option card: default hairline card; violet hairline + tint wash when selected -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tint_wash" />
            <stroke android:width="1dp" android:color="@color/signal_violet" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/pure_white" />
            <stroke android:width="1dp" android:color="@color/mist_gray" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
